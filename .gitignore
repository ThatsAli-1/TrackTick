# Intentional: do NOT list .env / .env.local / secrets here — this repo tracks them (see .cursor/rules).

# Dependencies — restored with `npm install`
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build & test output (regenerated by `next build`, tests, etc.)
/coverage
/.next/
/out/
/build

# Minimal ignore: large deps and bulky generated output only.
# Env, certs, logs, .vercel, etc. are tracked for transfer branches — use care.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# bulky generated / caches
/coverage
/.next/
/out/
/build
